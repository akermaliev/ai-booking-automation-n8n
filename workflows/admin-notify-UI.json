          "cachedResultUrl": "YOUR_SHEET_URL#gid=YOUR_SHEET_GID"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "requestId": "={{ $node[\"Webhook\"].json.body.requestId }}",
            "name": "={{ \"'\" + $node[\"Webhook\"].json.body.name }}",
            "createdAt": "={{ new Date().toISOString() }}",
            "house": "={{ $node[\"Webhook\"].json.body.house }}",
            "sauna": "={{ [\"true\",\"1\",\"yes\",\"y\"].includes(String($node[\"Webhook\"].json.body.sauna ?? \"\").toLowerCase()) }}",
            "jacuzzi": "={{ [\"true\",\"1\",\"yes\",\"y\"].includes(String($node[\"Webhook\"].json.body.jacuzzi ?? \"\").toLowerCase()) }}",
            "guests": "={{ Number(String($node[\"Webhook\"].json.body.guests ?? \"\").replace(/[^\\d]/g,\"\")) || 0 }}",
            "checkIn": "={{ $node[\"Webhook\"].json.body.checkIn }}",
            "paymentAmount": "={{ Number(String($node[\"Webhook\"].json.body.paymentAmount ?? $node[\"Webhook\"].json.body.deposit ?? \"\").replace(/[^\\d]/g,\"\")) || 0 }}",
            "checkOut": "={{ $node[\"Webhook\"].json.body.checkOut }}",
            "paymentType": "={{ $node[\"Webhook\"].json.body.paymentType ?? $node[\"Webhook\"].json.body.paymentMethod ?? \"—\" }}",
            "comments": "={{ $node[\"Webhook\"].json.body.comments ?? \"\" }}",
            "status": "PENDING",
            "contactId": "={{ $node[\"Webhook\"].json.body.contactId }}",
            "hot_tub": "={{ [\"true\",\"1\",\"yes\",\"y\"].includes(String($node[\"Webhook\"].json.body.hot_tub ?? \"\").toLowerCase()) }}",
            "phone": "={{\n  (() => {\n    const raw = String($node[\"Webhook\"].json.body.phone ?? \"\").trim();\n    if (!raw) return \"\";\n\n    // keep digits only\n    let digits = raw.replace(/\\D/g, \"\");\n\n    // -------- KG (Kyrgyzstan) --------\n    // 0777..., 777777777, 996...\n    if (\n      (digits.startsWith(\"0\") && digits.length === 10) ||\n      digits.length === 9 ||\n      digits.startsWith(\"996\")\n    ) {\n      if (digits.startsWith(\"0\")) digits = \"996\" + digits.slice(1);\n      if (digits.length === 9) digits = \"996\" + digits;\n\n      if (digits.startsWith(\"996\") && digits.length === 12) {\n        const rest = digits.slice(3);\n        return `kg 996 ${rest.slice(0,3)}-${rest.slice(3,5)}-${rest.slice(5,7)}-${rest.slice(7,9)}`;\n      }\n    }\n\n    // -------- US --------\n    if (digits.startsWith(\"1\") && digits.length === 11) {\n      const rest = digits.slice(1);\n      return `us 1 ${rest.slice(0,3)}-${rest.slice(3,6)}-${rest.slice(6,10)}`;\n    }\n\n    // -------- KZ --------\n    if (digits.startsWith(\"7\") && digits.length === 11) {\n      const rest = digits.slice(1);\n      return `kz 7 ${rest.slice(0,3)}-${rest.slice(3,6)}-${rest.slice(6,8)}-${rest.slice(8,10)}`;\n    }\n\n    // -------- UZ (Uzbekistan) --------\n    // 998901234567 or 901234567\n    if (digits.length === 9) {\n      digits = \"998\" + digits;\n    }\n    if (digits.startsWith(\"998\") && digits.length === 12) {\n      const rest = digits.slice(3);\n      return `uz 998 ${rest.slice(0,2)}-${rest.slice(2,5)}-${rest.slice(5,7)}-${rest.slice(7,9)}`;\n    }\n\n    // -------- fallback --------\n    return `intl ${digits}`;\n  })()\n}}\n"
          },
