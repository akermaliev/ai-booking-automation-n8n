              "value": "=={{ \n\"New booking request\\n\" +\n\"Request ID: #\" + ($json.body.requestId || $json.body.appId || \"-\") + \"\\n\\n\" +\n\"Name: \" + ($json.body.name || \"-\") + \"\\n\" +\n\"Phone: \" + ($json.body.phone || \"-\") + \"\\n\" +\n\"Dates: \" + ($json.body.checkIn || \"-\") + \" -> \" + ($json.body.checkOut || \"-\") + \"\\n\" +\n\"Guests: \" + ($json.body.guests || \"-\") + \"\\n\" +\n\"Property: \" + ($json.body.house || \"-\") + \"\\n\" +\n\"Payment: \" + (($json.body.paymentAmount || $json.body.deposit || \"-\")) + \" (\" + ($json.body.paymentType || $json.body.paymentMethod || \"-\") + \")\\n\\n\" +\n\"Please verify payment and select an action below.\"\n}}",
