    {
      "parameters": {
        "jsCode": "const raw = $json.callback_query?.data || \"\";\nconst parts = raw.split(\"|\");\n\nconst action = (parts[0] || \"\").replace(/^=/, \"\").trim();      // approve / reject / info\nconst requestId = (parts[1] || \"\").replace(/^=/, \"\").trim();   // 11223346\n\nconst adminId = $json.callback_query?.from?.id ?? null;\nconst chatId = $json.callback_query?.message?.chat?.id ?? null;\nconst messageId = $json.callback_query?.message?.message_id ?? null;\n\nreturn [{\n  raw,\n  action,\n  requestId,\n  adminId,\n  chatId,\n  messageId,\n}];\n"
      },
